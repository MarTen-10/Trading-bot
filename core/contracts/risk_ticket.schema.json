{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "risk_ticket.schema.json",
  "title": "RiskTicket",
  "type": "object",
  "required": [
    "type","risk_approval_id","timestamp_utc","strategy_id","strategy_version",
    "symbol","side","size","stop_price","target_price","regime_state",
    "feature_snapshot_hash","constraints","decision","signature"
  ],
  "properties": {
    "type": {"const": "risk_ticket"},
    "risk_approval_id": {"type": "string", "minLength": 8},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "strategy_id": {"type": "string"},
    "strategy_version": {"type": "string"},
    "symbol": {"type": "string"},
    "side": {"enum": ["LONG","SHORT"]},
    "size": {"type": "number", "exclusiveMinimum": 0},
    "stop_price": {"type": "number", "exclusiveMinimum": 0},
    "target_price": {"type": "number", "exclusiveMinimum": 0},
    "regime_state": {"type": "string"},
    "feature_snapshot_hash": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "constraints": {
      "type": "object",
      "required": ["max_daily_loss_pct","risk_per_trade_pct","one_open_position","isolated_margin_only"],
      "properties": {
        "max_daily_loss_pct": {"type": "number", "const": 3.0},
        "risk_per_trade_pct": {"type": "number", "const": 1.0},
        "one_open_position": {"type": "boolean", "const": true},
        "isolated_margin_only": {"type": "boolean", "const": true}
      },
      "additionalProperties": false
    },
    "decision": {"enum": ["ALLOW","DENY"]},
    "signature": {"type": "string", "minLength": 16}
  },
  "additionalProperties": false
}
